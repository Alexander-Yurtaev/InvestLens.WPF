<UserControl x:Class="InvestLens.App.UserControls.Spinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="SpinnerControl">

    <UserControl.Resources>
        <Style x:Key="SpinnerStyle" 
               TargetType="{x:Type Border}">
            <Setter Property="Width" Value="{Binding Size, ElementName=SpinnerControl, Mode=OneWay}"/>
            <Setter Property="Height" Value="{Binding Size, ElementName=SpinnerControl, Mode=OneWay}"/>
            <Setter Property="Margin" Value="0 0 0 20"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="{Binding Radius, ElementName=SpinnerControl, Mode=OneWay}"/>
        </Style>
    </UserControl.Resources>

    <Border x:Name="SpinnerBorder"
            Style="{StaticResource SpinnerStyle}">
        <Border.Resources>
            <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation
                            Storyboard.TargetName="SpinnerRotate"
                            Storyboard.TargetProperty="Angle"
                            From="0" To="360"
                            Duration="0:0:0.8"/>
            </Storyboard>
        </Border.Resources>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard Storyboard="{StaticResource SpinStoryboard}"/>
            </EventTrigger>
        </Border.Triggers>
        <Border Style="{StaticResource SpinnerStyle}"
                        BorderThickness="0 3 0 0"
                        BorderBrush="{StaticResource SpinnerBorderBrush}"
                        RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform x:Name="SpinnerRotate"/>
            </Border.RenderTransform>
        </Border>
    </Border>
</UserControl>

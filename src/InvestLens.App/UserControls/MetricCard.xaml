<UserControl x:Class="InvestLens.App.UserControls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0 0 20 0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
            </Style>
            <!--Metric Icon-->
            <Style x:Key="MetricIconBorderStyle" TargetType="Border">
                <Setter Property="Width" Value="48"/>
                <Setter Property="Height" Value="48"/>
                <Setter Property="Margin" Value="0 0 16 0"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
            </Style>
            <Style x:Key="MetricIconTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <!--Metric Info-->
            <Style x:Key="MetricLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#5A6E8A"/>
                <Setter Property="Margin" Value="0 0 0 6"/>
            </Style>
            <Style x:Key="MetricValueTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource BrandBlue}"/>
            </Style>
            <Style x:Key="MetricChangeTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="0 6 0 0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsPositive}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource BrandGreen}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource MetricCardStyle}">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource MetricIconBorderStyle}">
                <TextBlock Text="{Binding Icon}" Style="{StaticResource MetricIconTextBlockStyle}"/>
            </Border>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding Label}" Style="{StaticResource MetricLabelTextBlockStyle}"/>
                <TextBlock Grid.Row="1" Text="{Binding Value}" Style="{StaticResource MetricValueTextBlockStyle}"/>
                <TextBlock Grid.Row="2" Text="{Binding Change}" Style="{StaticResource MetricChangeTextBlockStyle}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="InvestLens.App.UserControls.PortfolioCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             xmlns:viewModel="clr-namespace:InvestLens.ViewModel;assembly=InvestLens.ViewModel"
             xmlns:converters="clr-namespace:InvestLens.App.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewModel:PortfolioInfo, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="20"
            BorderThickness="1"
            BorderBrush="#E9EDF2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0 0 0 16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Title}"
                           FontSize="18"
                           Foreground="#002855"/>
                <Border Grid.Column="1"
                        Background="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToBackgroundConverter.Instance}}"
                        Padding="10 4"
                        CornerRadius="20">
                    <TextBlock Text="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToStringConverter.Instance}}"
                               Foreground="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToForegroundConverter.Instance}}"
                               FontSize="11"
                               FontWeight="Medium"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>

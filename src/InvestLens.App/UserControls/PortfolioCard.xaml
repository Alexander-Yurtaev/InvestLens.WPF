<UserControl x:Class="InvestLens.App.UserControls.PortfolioCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             xmlns:converters="clr-namespace:InvestLens.App.Converters"
             xmlns:wrappers="clr-namespace:InvestLens.ViewModel.Wrappers;assembly=InvestLens.ViewModel"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance wrappers:PortfolioInfoWrapper, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="PortfolioStatsStackPanelStyle"
                   TargetType="{x:Type StackPanel}">
                <Setter Property="Margin" Value="0 0 0 16"/>
            </Style>
            <Style x:Key="PortfolioStatsBorderStyle"
                   TargetType="{x:Type Border}">
                <Setter Property="BorderThickness" Value=" 0 1 0 1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
                <Setter Property="Padding" Value="0 12"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="20"
            BorderThickness="1"
            BorderBrush="#E9EDF2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0 0 0 16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Title}"
                           FontSize="18"
                           Foreground="#002855"/>
                <Border Grid.Column="1"
                        Background="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToBackgroundConverter.Instance}}"
                        Padding="10 4"
                        CornerRadius="20">
                    <TextBlock Text="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToStringConverter.Instance}}"
                               Foreground="{Binding PortfolioType, Converter={x:Static converters:PortfolioTypeToForegroundConverter.Instance}}"
                               FontSize="11"
                               FontWeight="Medium"/>
                </Border>
            </Grid>
            <Border Grid.Row="1"
                    Style="{StaticResource PortfolioStatsBorderStyle}">
                <ItemsControl
                          ItemsSource="{Binding PortfolioStats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>

                            <StackPanel Orientation="Horizontal"
                                        Style="{StaticResource PortfolioStatsStackPanelStyle}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type wrappers:PortfolioStatsWrapper}">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Title}" 
                                       FontSize="11"
                                       Foreground="#5A6E8A"/>
                                <TextBlock Text="{Binding ValueDisplay}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding ValueDisplay, Converter={x:Static converters:ValueDisplayToForegroundConverter.Instance}, ConverterParameter=#002855}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
    </Border>
</UserControl>

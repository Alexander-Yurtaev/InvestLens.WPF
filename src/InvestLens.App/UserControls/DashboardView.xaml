<UserControl x:Class="InvestLens.App.UserControls.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             xmlns:pages="clr-namespace:InvestLens.ViewModel.Pages;assembly=InvestLens.ViewModel"
             xmlns:model="clr-namespace:InvestLens.Model;assembly=InvestLens.Model"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance pages:DashboardViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="WelcomeSectionStyle" TargetType="{x:Type StackPanel}">
                <Setter Property="Margin" Value="0 0 0 28"/>
            </Style>
            <Style x:Key="H1Style" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="Foreground" Value="#002855"/>
                <Setter Property="Margin" Value="0 0 0 8"/>
            </Style>
            <Style x:Key="PStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="#5A6E8A"/>
            </Style>
            <Style x:Key="MetricsGridStyle" TargetType="{x:Type Grid}">
                <Setter Property="Margin" Value="0 0 0 32"/>
            </Style>
            <Style x:Key="CardStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2" 
                                          BlurRadius="8" 
                                          Opacity="0.04"
                                          Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="CardHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#002855"/>
            </Style>
            <!--PeriodSelector-->
            <Style x:Key="PeriodSelectorStyle" TargetType="{x:Type RadioButton}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#5A6E8A"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            <Border Cursor="Hand"
                                    Padding="8 4"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type RadioButton}}, Path=Content}"
                                           FontSize="12"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="#C8102E"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ChartPlaceholderStyle" TargetType="{x:Type Border}">
                <Setter Property="Height" Value="220"/>
            </Style>
            <Style x:Key="HeaderStyle" TargetType="{x:Type Grid}">
                <Setter Property="Margin" Value="0 0 0 16"/>
            </Style>
            <Style x:Key="LinkStyle" TargetType="{x:Type Button}">
                <Setter Property="Foreground" Value="#C8102E"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!--Activity-->
            <Style x:Key="ActivityListStyle" TargetType="{x:Type ListView}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style x:Key="ActivityItemStyle" TargetType="{x:Type Border}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="0 12 0 0"/>
                <Setter Property="Padding" Value="0 0 0 12"/>
                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
            </Style>
            <Style x:Key="ActivityIcon" TargetType="{x:Type TextBlock}">
                <Setter Property="Width" Value="32"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="Margin" Value="0 0 12 0"/>
            </Style>
            <Style x:Key="ActivityInfoStyle" TargetType="{x:Type StackPanel}">
                <Setter Property="Margin" Value="0 0 12 0"/>
            </Style>
            <Style x:Key="ActivityTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
            <Style x:Key="ActivityDescriptionStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#6E7288"/>
            </Style>
            <Style x:Key="ActivityAmountStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0 0 28 0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="ActivityDateStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#8E92A8"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <DataTemplate DataType="{x:Type model:ActivityItem}">
                <Border Style="{StaticResource ActivityItemStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Icon}" Style="{StaticResource ActivityIcon}"/>
                        <StackPanel Grid.Column="1" Orientation="Vertical" Style="{StaticResource ActivityInfoStyle}">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource ActivityTitleStyle}"/>
                            <TextBlock FontSize="4"/>
                            <TextBlock Text="{Binding Description}" Style="{StaticResource ActivityDescriptionStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding Amount}" Style="{StaticResource ActivityAmountStyle}"/>
                        <TextBlock Grid.Column="3" Text="{Binding Date}" Style="{StaticResource ActivityDateStyle}"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Style="{StaticResource WelcomeSectionStyle}">
            <TextBlock Style="{StaticResource H1Style}" Text="{Binding WelcomeTitle}"/>
            <TextBlock Style="{StaticResource PStyle}" Text="{Binding WelcomeDescription}"/>
        </StackPanel>
        <Grid Grid.Row="1" Style="{StaticResource MetricsGridStyle}">
            <ItemsControl ItemsSource="{Binding MetricCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Items.Count, 
                          RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                     Rows="1"
                                     HorizontalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:MetricCard/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0 0 12 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Style="{StaticResource HeaderStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Style="{StaticResource CardHeaderStyle}"
                                   Text="Динамика портфеля"/>

                        <RadioButton Grid.Column="2" GroupName="PeriodSelector" Content="1М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="3" GroupName="PeriodSelector" Content="3М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="4" GroupName="PeriodSelector" Content="6М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="5" GroupName="PeriodSelector" Content="1Г" Style="{StaticResource PeriodSelectorStyle}"/>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource ChartPlaceholderStyle}">
                        <Viewbox>
                            <Grid>
                                <Polyline Points="0,150 50,120 100,140 150,80 200,90 250,40 300,60 350,30 400,50 450,70 500,45 550,60 600,40" 
                                          Fill="Transparent" 
                                          Stroke="#C8102E" 
                                          StrokeThickness="2"/>
                                <Polygon Points="0,150 50,120 100,140 150,80 200,90 250,40 300,60 350,30 400,50 450,70 500,45 550,60 600,40 600,180 0,180" 
                                         Fill="#1AC8102E"/>
                            </Grid>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Column="1" 
                    Style="{StaticResource CardStyle}" 
                    Margin="12 0 0 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" 
                          Style="{StaticResource HeaderStyle}"
                          Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Style="{StaticResource CardHeaderStyle}"
                                   Text="Последние операции"/>

                        <Button Grid.Column="2" Content="Все →" Style="{StaticResource LinkStyle}"/>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource ChartPlaceholderStyle}">
                        <ListView ItemsSource="{Binding ActivityItems}"
                                  Style="{StaticResource ActivityListStyle}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="{x:Type ListViewItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="InvestLens.App.UserControls.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             xmlns:pages="clr-namespace:InvestLens.ViewModel.Pages;assembly=InvestLens.ViewModel"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance pages:DashboardViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="WelcomeSectionStyle" TargetType="StackPanel">
                <Setter Property="Margin" Value="0 0 0 28"/>
            </Style>
            <Style x:Key="H1Style" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="Foreground" Value="#002855"/>
                <Setter Property="Margin" Value="0 0 0 8"/>
            </Style>
            <Style x:Key="PStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#5A6E8A"/>
            </Style>
            <Style x:Key="MetricsGridStyle" TargetType="Grid">
                <Setter Property="Margin" Value="0 0 0 32"/>
            </Style>
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="2" 
                                          BlurRadius="8" 
                                          Opacity="0.04"
                                          Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="CardHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#002855"/>
            </Style>
            <!--PeriodSelector-->
            <Style x:Key="PeriodSelectorStyle" TargetType="RadioButton">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#5A6E8A"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border Cursor="Hand"
                                    Padding="8 4"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type RadioButton}}, Path=Content}"
                                           FontSize="12"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="#C8102E"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ChartPlaceholderStyle" TargetType="Border">
                <Setter Property="Height" Value="200"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Style="{StaticResource WelcomeSectionStyle}">
            <TextBlock Style="{StaticResource H1Style}" Text="{Binding WelcomeTitle}"/>
            <TextBlock Style="{StaticResource PStyle}" Text="{Binding WelcomeDescription}"/>
        </StackPanel>
        <Grid Grid.Row="1" Style="{StaticResource MetricsGridStyle}">
            <ItemsControl ItemsSource="{Binding MetricCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Items.Count, 
                          RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                     Rows="1"
                                     HorizontalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:MetricCard/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0 0 12 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Style="{StaticResource CardHeader}"
                                   Text="Динамика портфеля"/>

                        <RadioButton Grid.Column="2" GroupName="PeriodSelector" Content="1М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="3" GroupName="PeriodSelector" Content="3М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="4" GroupName="PeriodSelector" Content="6М" Style="{StaticResource PeriodSelectorStyle}"/>
                        <RadioButton Grid.Column="5" GroupName="PeriodSelector" Content="1Г" Style="{StaticResource PeriodSelectorStyle}"/>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource ChartPlaceholderStyle}">

                    </Border>
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12 0 0 0">
                
            </Border>
        </Grid>
    </Grid>
</UserControl>
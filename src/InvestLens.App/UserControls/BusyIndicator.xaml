<UserControl x:Class="InvestLens.App.UserControls.BusyIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="BlockerStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#7A000000"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <BlurEffect Radius="3" KernelType="Gaussian"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LoaderContainerStyle"
            TargetType="Border">
            <Setter Property="Width" Value="290"/>
            <Setter Property="Height" Value="180"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Padding" Value="48 32"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect 
                                BlurRadius="40" 
                                ShadowDepth="20"
                                Opacity="1"
                                Color="{StaticResource SpinnerBackgroundColor}"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SpinnerStyle" 
               TargetType="{x:Type Border}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0 0 0 20"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>
        <Style x:Key="LoaderTextStyle"
               TargetType="{x:Type Label}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource BlockerStyle}"/>
        <Border Style="{StaticResource LoaderContainerStyle}">
            <StackPanel>
                <Border Style="{StaticResource SpinnerStyle}">
                    <Border.Resources>
                        <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
                            <DoubleAnimation
                            Storyboard.TargetName="SpinnerRotate"
                            Storyboard.TargetProperty="Angle"
                            From="0" To="360"
                            Duration="0:0:0.8"/>
                        </Storyboard>
                    </Border.Resources>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource SpinStoryboard}"/>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border Style="{StaticResource SpinnerStyle}"
                        BorderThickness="0 3 0 0"
                        BorderBrush="{StaticResource SpinnerBorderBrush}"
                        RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>
                <Label Content="Выполняется операция..."
                       Style="{StaticResource LoaderTextStyle}"
                       Margin="0 0 0 8"/>
                <Label Content="Пожалуйста, подождите"
                       Style="{StaticResource LoaderTextStyle}"
                       Margin="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

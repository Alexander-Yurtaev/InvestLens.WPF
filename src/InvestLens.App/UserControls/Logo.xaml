<UserControl x:Class="InvestLens.App.UserControls.Logo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <Border Width="36"
                Height="36"
                Background="{StaticResource BrandRedBrush}"
                CornerRadius="10">
            <TextBlock FontWeight="Bold"
                       FontSize="18"
                       Foreground="{StaticResource BackgroundSecondaryBrush}"
                       Margin="6"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">IL</TextBlock>
        </Border>
        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Margin="12"
                   Foreground="{StaticResource BackgroundSecondaryBrush}"
                   Text="Invest Lens"/>
    </StackPanel>
</UserControl>

<UserControl x:Class="InvestLens.App.Views.PortfolioDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvestLens.App.UserControls"
             xmlns:wrappers="clr-namespace:InvestLens.ViewModel.Wrappers;assembly=InvestLens.ViewModel"
             xmlns:converters="clr-namespace:InvestLens.App.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <!--<b:Interaction.Behaviors>
        <behaviors:LoadBehavior/>
    </b:Interaction.Behaviors>-->

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:TransactionEventsToStringConverter x:Key="TransactionEventsToStringConv"/>
            
            <Style x:Key="PortfolioCard" TargetType="{x:Type Button}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <local:Card MinWidth="340" Margin="12 0"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
                <Setter Property="Foreground" Value="#5A6E8A"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#E9EDF2"
                                    BorderThickness="0,0,1,1"
                                    Padding="12,0">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <local:ContentHeader Grid.Row="0" 
                             DataContext="{Binding ContentHeaderVm}" 
                             Style="{StaticResource ContentHeaderStyle}"/>
        <Border Grid.Row="1"
                Background="Transparent"
                Margin="0 0 0 24"
                Padding="20"
                CornerRadius="16"
                BorderThickness="1"
                BorderBrush="#E9EDF2">
            <Grid>
                <ItemsControl ItemsSource="{Binding MetricCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding Items.Count, 
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                         Rows="1"
                                         HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:MetricCard/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
        <TabControl Grid.Row="2">
            <TabItem Header="{Binding SecuritiesHeader, FallbackValue='Активы'}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <CheckBox Grid.Row="0"
                              FontWeight="Bold"
                              FontSize="14"
                              Margin="8 8 0 14"
                              Content="Показывать проданные"
                              IsChecked="{Binding ShowSold}"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SecuritiesView}"
                              AutoGenerateColumns="False"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Актив" Binding="{Binding SecId}"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Count}"/>
                            <DataGridTextColumn Header="Текущая цена" Binding="{Binding CurrentPrice, StringFormat='F2'}"/>
                            <DataGridTextColumn Header="Средняя цена" Binding="{Binding AveragePrice, StringFormat='F2'}"/>
                            <DataGridTextColumn Header="Общая стоимость" Binding="{Binding TotalPrice, StringFormat='F2'}"/>
                            <DataGridTextColumn Header="Прибыль" Binding="{Binding ProfitDisplay}"/>
                            <DataGridTextColumn Header="Общие дивиденты" Binding="{Binding DividendCount, StringFormat='F2'}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Операции">
                <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Operations}"
                              AutoGenerateColumns="False"
                              EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy HH:mm:ss}"/>
                        <DataGridTextColumn Header="Актив" Binding="{Binding SecId}"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding OperationType, Converter={StaticResource TransactionEventsToStringConv}}"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding  Count, StringFormat=F2}"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat='F2'}"/>
                        <DataGridTextColumn Header="Комментарий" Binding="{Binding Description}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

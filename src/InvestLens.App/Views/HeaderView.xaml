<UserControl x:Class="InvestLens.App.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModel="clr-namespace:InvestLens.ViewModel;assembly=InvestLens.ViewModel"
             xmlns:conv="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance viewModel:HeaderViewModel, IsDesignTimeCreatable=True}"
             d:DesignWidth="800">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!--Header Container-->
        <Style x:Key="HeaderContainerStyle" TargetType="Border">
            <Setter Property="Padding" Value="32, 20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!--PageInfo-->
        <Style x:Key="PageInfoTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandBlueBrush}"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>
        <Style x:Key="PageInfoDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>
        <!--Notification Badge-->
        <Style x:Key="NotificationIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="{StaticResource BrandGoldBrush}"/>
            <Setter Property="Margin" Value="11 0"/>
        </Style>
        <Style x:Key="NotificationBadgeBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0 -6 4 0"/>
            <Setter Property="Background" Value="{StaticResource BrandRedBrush}"/>
            <Setter Property="Padding" Value="6 2"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style x:Key="NotificationBadgeTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BackgroundSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <!--AvatarStyle-->
        <Style x:Key="AvatarBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource BrandRedColor}" Offset="0"/>
                        <GradientStop Color="#E64A2E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="100"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandRedBrush}"/>
        </Style>
        <Style x:Key="AvatarTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="UserNameStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="6 0 0 0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
    </UserControl.Resources>
    <Border Style="{StaticResource HeaderContainerStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical"
                        Grid.Column="0">
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource PageInfoTitleStyle}"/>
                <TextBlock Text="{Binding Description}"
                           Style="{StaticResource PageInfoDescriptionStyle}"/>
            </StackPanel>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0"
                               Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Grid.RowSpan="2"
                               Text="🔔"
                               Style="{StaticResource NotificationIconStyle}"/>
                    <Border Grid.Column="1"
                            Grid.Row="0"
                            Visibility="{Binding NotificationsManager.HasNotifications, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource NotificationBadgeBorderStyle}">
                        <TextBlock Text="{Binding NotificationsManager.NotificationsCountDisplay}" 
                                   Style="{StaticResource NotificationBadgeTextBlockStyle}"/>
                    </Border>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AvatarBorderStyle}">
                        <TextBlock HorizontalAlignment="Stretch" TextAlignment="Center"
                            Style="{StaticResource AvatarTextBlockStyle}"
                            Text="{Binding UserAvatar}"/>
                    </Border>
                    <TextBlock Grid.Column="1"  
                        Text="{Binding UserFullNameInShortFormat}"
                        Style="{StaticResource UserNameStyle}"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>

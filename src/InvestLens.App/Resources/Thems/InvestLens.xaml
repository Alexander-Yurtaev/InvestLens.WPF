<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--Основные цвета бренда-->
    <SolidColorBrush x:Key="BrandBlue" Color="#002855"/>
    <SolidColorBrush x:Key="BrandRed" Color="#C8102E"/>
    <SolidColorBrush x:Key="BrandGreen" Color="#2C8C6E"/>
    <SolidColorBrush x:Key="BrandGold" Color="#E6B84E"/>

    <!--Фоновые цвета-->
    <SolidColorBrush x:Key="BackgroundPrimary" Color="#F8FAFE"/>
    <SolidColorBrush x:Key="BackgroundSecondary" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BackgroundHover" Color="#1AC8102E"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E9EDF2"/>

</ResourceDictionary>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Стиль для TabItem -->
    <Style TargetType="TabItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border" 
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="30"
                        Padding="24,8"
                        Margin="0,0,8,24"
                        Cursor="Hand">
                        <TextBlock x:Name="HeaderText"
                               Text="{TemplateBinding Header}"
                               FontSize="14"
                               FontWeight="Medium"
                               Foreground="{StaticResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrandRedBrush}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BackgroundPrimaryBrush}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource BrandRedBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrandRedBrush}"/>
                            <Setter TargetName="HeaderText" Property="Foreground" Value="{StaticResource BackgroundSecondaryBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Стиль для TabPanel (область с вкладками) -->
    <Style TargetType="TabPanel">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Margin" Value="0,0,0,24"/>
    </Style>
</ResourceDictionary>
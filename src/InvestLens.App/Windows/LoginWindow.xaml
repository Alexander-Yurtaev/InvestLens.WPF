<Window x:Class="InvestLens.App.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.UserControls"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
        mc:Ignorable="d"
        Title="Login" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource WindowStyle}">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
    </b:Interaction.Behaviors>

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConv"/>

            <Style x:Key="LeftSideStyle"
                   TargetType="Border">
                <Setter Property="CornerRadius" Value="32 0 0 32"/>
                <Setter Property="Padding" Value="48"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#002855" Offset="0"/>
                            <GradientStop Color="#003D7A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="RightSideStyle"
                   TargetType="Border">
                <Setter Property="CornerRadius" Value="0 32 32 0"/>
                <Setter Property="Padding" Value="48"/>
                <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
            </Style>
            <Style x:Key="H1Style" 
                   TargetType="TextBlock">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0 0 0 8"/>
            </Style>
            <Style x:Key="H2Style" 
                   TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BackgroundSecondary}"/>
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
            <Style x:Key="PBlackStyle" 
                   TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BackgroundSecondary}"/>
                <Setter Property="Opacity" Value="0.8"/>
                <Setter Property="FontSize" Value="15"/>
            </Style>
            <Style x:Key="PWhiteStyle" 
                   TargetType="TextBlock">
                <Setter Property="Foreground" Value="#5A6E8A"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="#1E2A3E"/>
                <Setter Property="Margin" Value="0 0 0 8"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="16 12"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E9EDF2"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12">
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Margin="5,0"
                                              VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Validation.ErrorTemplate">
                    <Setter.Value>
                        <ControlTemplate>
                            <StackPanel>
                                <AdornedElementPlaceholder x:Name="placeholder"/>
                                <TextBlock Text="{Binding ElementName=placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                           Foreground="{StaticResource BrandRed}"/>
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Margin" Value="3 0 0 20"/>
                        <Setter Property="ToolTip" 
                                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource WindowBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                  Style="{StaticResource LeftSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0 0 0 48">
                        <local:Logo/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Margin="0 0 0 16">
                            <TextBlock Text="Начни свой путь" 
                                       Style="{StaticResource H2Style}"/>
                            <TextBlock Text="в инвестициях" 
                                       Style="{StaticResource H2Style}"/>
                        </StackPanel>
                        <TextBlock Text="Присоединяйтесь к тысячам инвесторов" 
                                   Style="{StaticResource PBlackStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📊" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Аналитика в реальном времени" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📁" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Несколько портфелей" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="🔒" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Безопасное хранение данных" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource RightSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0 0 0 28">
                        <TextBlock Text="Вход в аккаунт" 
                                   Style="{StaticResource H1Style}"/>
                        <TextBlock Text="Введите свои данные для входа" 
                                   Style="{StaticResource PWhiteStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <StackPanel Margin="0 0 0 20">
                            <Label Content="Email" Target="EmailTextBox"/>
                            <TextBox x:Name="EmailTextBox" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 0 20">
                            <Label Content="Пароль" Target="PasswordTextBox"/>
                            <PasswordBox x:Name="PasswordTextBox" />
                        </StackPanel>
                        <Button Content="Войти" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoginCommand}"/>
                        <Button Content="Выход" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Visibility="{Binding ShowErrorMessage, Converter={StaticResource BooleanToVisibilityConv}}"
                                   Style="{StaticResource ErrorMessageStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Нет аккаунта?"
                                   FontSize="14"
                                   Foreground="#5A6E8A"
                                   Margin="0 0 4 0"/>
                        <Button Content="Зарегистрироваться" 
                                FontWeight="Medium"
                                Command="{Binding RegistrationCommand}"
                                Style="{StaticResource LinkStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="InvestLens.App.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.UserControls"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
        mc:Ignorable="d"
        Title="Login" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource WindowStyle}">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
    </b:Interaction.Behaviors>

    <Border Style="{StaticResource WindowBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                  Style="{StaticResource LeftSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0 0 0 48">
                        <local:Logo/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Margin="0 0 0 16">
                            <TextBlock Text="Начни свой путь" 
                                       Style="{StaticResource H2Style}"/>
                            <TextBlock Text="в инвестициях" 
                                       Style="{StaticResource H2Style}"/>
                        </StackPanel>
                        <TextBlock Text="Присоединяйтесь к тысячам инвесторов" 
                                   Style="{StaticResource PBlackStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📊" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Аналитика в реальном времени" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📁" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Несколько портфелей" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="🔒" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Безопасное хранение данных" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource RightSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0 0 0 28">
                        <TextBlock Text="Вход в аккаунт" 
                                   Style="{StaticResource H1Style}"/>
                        <TextBlock Text="Введите свои данные для входа" 
                                   Style="{StaticResource PWhiteStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <StackPanel Margin="0 0 0 20">
                            <Label Content="Login" Target="LoginTextBox"/>
                            <TextBox x:Name="LoginTextBox" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 0 20">
                            <Label Content="Пароль" Target="PasswordTextBox"/>
                            <PasswordBox x:Name="PasswordTextBox">
                                <b:Interaction.Behaviors>
                                    <behaviors:PasswordBoxBehavior PropertyName="Password"/>
                                </b:Interaction.Behaviors>
                            </PasswordBox>
                        </StackPanel>
                        <Button Content="Войти" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoginCommand}"/>
                        <Button Content="Выход" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Visibility="{Binding ShowErrorMessage, Converter={StaticResource BooleanToVisibilityConv}}"
                                   Style="{StaticResource ErrorMessageStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Нет аккаунта?"
                                   FontSize="14"
                                   Foreground="#5A6E8A"
                                   Margin="0 0 4 0"/>
                        <Button Content="Зарегистрироваться" 
                                FontWeight="Medium"
                                Command="{Binding RegistrationCommand}"
                                Style="{StaticResource LinkStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

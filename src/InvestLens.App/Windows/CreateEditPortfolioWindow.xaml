<Window x:Class="InvestLens.App.Windows.CreateEditPortfolioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.Windows"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
        xmlns:viewModel="clr-namespace:InvestLens.ViewModel;assembly=InvestLens.ViewModel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModel:CreateEditPortfolioWindowViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding Title}" Height="560" Width="580"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource WindowStyle}"
        ShowInTaskbar="False">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
        <behaviors:PortfolioTypeBehavior IsPortfolioComplexType="{Binding IsPortfolioComplexType}"/>
    </b:Interaction.Behaviors>

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConv"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource WindowBorderStyle}"
            Padding="28 24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderThickness="0 0 0 1"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Title}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrandBlue}"/>
                    <Button  Grid.Column="1"
                             Content="X"
                             FontSize="24"
                             Command="{Binding CloseCommand}"
                             Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Padding="28 24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" 
                                Orientation="Vertical"
                                Margin="0 0 0 24">
                        <Label Target="PortfolioName">
                            <TextBlock>
                                <Bold>Название портфеля:</Bold>
                                <Run Foreground="{StaticResource BrandRed}">*</Run>
                            </TextBlock>
                        </Label>
                        <TextBox x:Name="PortfolioName"
                                 Text="{Binding Name}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" 
                                Orientation="Vertical"
                                Margin="0 0 0 24">
                        <Label Target="PortfolioDescription">
                            <TextBlock>
                                <Bold>Описание портфеля:</Bold>
                            </TextBlock>
                        </Label>
                        <TextBox x:Name="PortfolioDescription"
                                 Text="{Binding Description}"
                                 MinLines="3"
                                 MaxLines="5"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Orientation="Vertical"
                                Margin="0 0 0 24">
                        <Label>
                            <TextBlock>
                                <Bold>Тип портфеля:</Bold>
                                <Run Foreground="{StaticResource BrandRed}">*</Run>
                            </TextBlock>
                        </Label>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Height="30">
                                <RadioButton IsChecked="{Binding IsPortfolioSimpleType}"
                                             GroupName="PortfolioType"/>
                            </Viewbox>
                            <Label Content="Простой"
                                   FontWeight="Bold"
                                   Margin="0 0 24 0"/>
                            <Viewbox Height="30">
                                <RadioButton IsChecked="{Binding IsPortfolioComplexType}"
                                             GroupName="PortfolioType"/>
                            </Viewbox>
                            <Label Content="Составной"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid Grid.Row="3" 
                          Margin="0 0 0 24"
                          Visibility="{Binding IsPortfolioComplexType, Converter={StaticResource BooleanToVisibilityConv}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0">
                            <TextBlock>
                                <Bold>Выберите портфели для объединения:</Bold>
                            </TextBlock>
                        </Label>
                        <ListView Grid.Row="1">
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label VerticalContentAlignment="Center">Яблоко</Label>
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label VerticalContentAlignment="Center">Киви</Label>
                            </StackPanel>
                            <StackPanel Margin="5" Orientation="Horizontal">
                                <Label VerticalContentAlignment="Center">Лимон</Label>
                            </StackPanel>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Row="2"
                    Padding="0 16 0 0"
                    BorderThickness="0 1 0 0"
                    BorderBrush="{StaticResource BorderBrush}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Отмена"
                            Margin="0 0 6 0"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button Content="{Binding ActionTitle}"
                            Margin="6 0 0 0"
                            Command="{Binding ActionCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

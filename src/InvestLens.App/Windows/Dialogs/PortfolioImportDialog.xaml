<Window x:Class="InvestLens.App.Windows.Dialogs.PortfolioImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.Windows.Dialogs"
        xmlns:usercontrols="clr-namespace:InvestLens.App.UserControls"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
        mc:Ignorable="d"
        Title="{Binding Header}" 
        Height="640" Width="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Style="{StaticResource WindowStyle}">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
    </b:Interaction.Behaviors>

    <Window.Resources>
        <Style x:Key="ImportFileAreaStyle" 
               TargetType="{x:Type Button}">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Grid.Row="1"
                                BorderThickness="2"
                                BorderBrush="#E9EDF2"
                                Padding="32"
                                CornerRadius="16"
                                Cursor="{TemplateBinding Cursor}"
                                Background="#F8FAFE">
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="1" 
                                           Text="📁"
                                           FontSize="{TemplateBinding FontSize}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Margin="0 0 0 12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2"
                                           Text="Нажмите для выбора файла"
                                           FontSize="14"
                                           Foreground="#5A6E8A"
                                           Margin="0 0 0 8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3"
                                           Text="Поддерживаются: CSV"
                                           FontSize="12"
                                           Foreground="#8E92A8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FileAreaStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="28"/>
            <Setter Property="Width" Value="400"/>
            <Setter Property="Height" Value="300"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FileSelectedNotificationStyle"
               TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16 12"/>
            <Setter Property="Margin" Value="0 16 0 0"/>
            <Setter Property="Background" Value="#1A2C8C6E"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ImportModeBorderStyle"
               TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFE"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0 0 0 24"/>
        </Style>
        <Style x:Key="ImportModeRadioStyle"
               TargetType="{x:Type RadioButton}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E2A3E"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
            <Setter Property="Padding" Value="0 8"/>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource WindowBorderStyle}"
            Padding="28 24 28 16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderThickness="0 0 0 1"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                        <TextBlock Text="{Binding Icon}"
                                   Style="{StaticResource H2WhiteStyle}"/>
                        <TextBlock Text="{Binding Header}"
                                   Margin="12 0 0 0"
                                   Style="{StaticResource H2WhiteStyle}"/>
                    </StackPanel>
                    <Button  Grid.Column="1"
                             Content="X"
                             Command="{Binding CloseCommand}"
                             Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" 
                       Content="Файл для импорта"/>
                <Border Grid.Row="1" 
                        Style="{StaticResource FileAreaStyle}">
                    <Button Style="{StaticResource ImportFileAreaStyle}"
                            Command="{Binding SelectFileCommand}"/>
                </Border>
                <Border Grid.Row="1"
                        Style="{StaticResource FileSelectedNotificationStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                               Text="{Binding FileName}"
                               TextWrapping="WrapWithOverflow"
                               FontSize="13"
                               Foreground="#2C8C6E"
                               Opacity="1"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                        <Button Grid.Column="1"
                            Content="X"
                            FontSize="18"
                            Cursor="Hand"
                            Foreground="#8E92A8"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding CancelSelectFileCommand}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0"
                           Content="Режим импорта"/>
                    <Border Grid.Row="1"
                            Style="{StaticResource ImportModeBorderStyle}">
                        <StackPanel>
                            <RadioButton GroupName="ImportMode"
                                         Content="Объединить с существующими данными"
                                         IsChecked="{Binding MergeMode}"
                                         Style="{StaticResource ImportModeRadioStyle}"/>
                            <RadioButton GroupName="ImportMode"
                                         Content="Заменить текущий портфель"
                                         IsChecked="{Binding RecreateMode}"
                                         Style="{StaticResource ImportModeRadioStyle}"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Visibility="{Binding HasErrorMessage, Converter={StaticResource BooleanToVisibilityConv}}"
                                       Style="{StaticResource ErrorMessageStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            <Border Grid.Row="2"
                    Padding="28 16 28 24"
                    BorderThickness="0 1 0 0"
                    BorderBrush="#E9EDF2">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Отмена"
                            Margin="0 0 6 0"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConv}}"/>
                    <Button Content="{Binding ActionContext}"
                            Margin="6 0 0 0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AcceptCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

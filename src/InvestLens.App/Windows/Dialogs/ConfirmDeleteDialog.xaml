<Window x:Class="InvestLens.App.Windows.Dialogs.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.Windows.Dialogs"
        xmlns:usercontrols="clr-namespace:InvestLens.App.UserControls"
        mc:Ignorable="d"
        Title="ConfirmDeleteDialog" 
        Height="640" Width="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Style="{StaticResource WindowStyle}">

    <Border Style="{StaticResource WindowBorderStyle}"
            Padding="28 24 28 16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderThickness="0 0 0 1"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                        <TextBlock Text="🗑️"
                                   Style="{StaticResource H2WhiteStyle}"/>
                        <TextBlock Text="Удаление портфеля"
                                   Margin="12 0 0 0"
                                   Style="{StaticResource H2WhiteStyle}"/>
                    </StackPanel>
                    <Button  Grid.Column="1"
                             Content="X"
                             Command="{Binding CloseCommand}"
                             Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" 
                                Orientation="Vertical"
                                Margin="0 0 0 24">
                        <TextBlock  
                           Text="Вы действительно хотите удалить портфель"
                           FontSize="21"
                           Foreground="#1E2A3E"
                           Margin="0 0 0 12"/>
                        <TextBlock Text="{Binding PortfolioName, FallbackValue='Name', StringFormat='&quot;{0}&quot;'}" 
                                   FontWeight="Bold"
                                   FontSize="19"
                                   Foreground="#5A6E8A"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                        Background="#0DC8102E"
                        BorderThickness="3 0 0 0"
                        BorderBrush="#C8102E"
                        Padding="16"
                        CornerRadius="12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrandGold}"
                                           FontSize="19"
                                           Margin="0 0 0 12"/>
                                <TextBlock Text="Это действие нельзя отменить" 
                                           FontWeight="Bold"
                                           Margin="3 0 0 12"
                                           Typography.Capitals="AllSmallCaps"
                                           FontSize="19"
                                           Foreground="{StaticResource BrandRed}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️"
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="{StaticResource BrandGold}"/>
                                <TextBlock Text="Все активы портфеля будут удалены" 
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="#5A6E8A"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️"
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="{StaticResource BrandGold}"/>
                                <TextBlock Text="История операций будет потеряна" 
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="#5A6E8A"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️"
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="{StaticResource BrandGold}"/>
                                <TextBlock Text="Дивидендный календарь будет очищен" 
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="#5A6E8A"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️"
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="{StaticResource BrandGold}"/>
                                <TextBlock Text="Статистика доходности станет недоступна" 
                                           FontSize="19"
                                           Margin="0 6"
                                           Foreground="#5A6E8A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" 
                        Padding="12"
                        CornerRadius="12">
                        <StackPanel Orientation="Horizontal"
                                Margin="0 24"
                                Background="#F8FAFE">
                            <CheckBox IsChecked="{Binding IsAgree}"/>
                            <TextBlock FontSize="19"
                                       Foreground="#5A6E8A"
                                       TextWrapping="WrapWithOverflow"
                                       Margin="12 0 0 0"
                                       Width="400">
                                    <Run>
                                        Я понимаю, что удаление портфеля
                                    </Run>
                                    <Bold>
                                        необратимо
                                    </Bold>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Border Grid.Row="2"
                    Padding="28 16 28 24"
                    BorderThickness="0 1 0 0"
                    BorderBrush="#E9EDF2">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Отмена"
                            Margin="0 0 6 0"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CloseCommand}"/>
                    <Button Content="Удалить портфель"
                            Margin="6 0 0 0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

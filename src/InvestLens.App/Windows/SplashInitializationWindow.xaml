<Window x:Class="InvestLens.App.Windows.SplashInitializationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.Windows"
        xmlns:usercontrols="clr-namespace:InvestLens.App.UserControls"
        xmlns:design="clr-namespace:InvestLens.ViewModel.Design;assembly=InvestLens.ViewModel"
        xmlns:wrappers="clr-namespace:InvestLens.ViewModel.Wrappers;assembly=InvestLens.ViewModel"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors" 
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance design:DesignSplashInitializationWindowViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding Header}" 
        Height="580" Width="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Style="{StaticResource WindowStyle}">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
        <behaviors:LoadBehavior/>
    </b:Interaction.Behaviors>

    <Window.Resources>
        <Style x:Key="IconSpinnerStyle" 
               TargetType="{x:Type usercontrols:Spinner}">
            <Setter Property="Size" Value="28"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Run">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource WindowBorderStyle}"
            Padding="28 24 28 16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderThickness="0 0 0 1"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <usercontrols:IconLogo Grid.Column="0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Header}"
                                   Margin="12 0 0 0"
                                   Style="{StaticResource H2WhiteStyle}"/>
                    </Grid>
                    <Button  Grid.Column="1"
                             Content="X"
                             Command="{Binding XbuttonCommand}"
                             Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Margin="0 0 0 28"
                                  Grid.Row="0">
                        <ItemsControl ItemsSource="{Binding InitSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type wrappers:InitStepWrapper}">
                                    <Border Padding="0 12 12 12"
                                            BorderThickness="0 0 0 1"
                                            BorderBrush="#F0F2F5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       Width="28"
                                                       FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <usercontrols:Spinner Grid.Column="0"
                                                                  Style="{StaticResource IconSpinnerStyle}"/>
                                            <StackPanel Grid.Column="1"
                                                Orientation="Vertical"
                                                Margin="14 0">
                                                <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource PrimaryForeground}"
                                                   Margin="0 0 0 2"/>
                                                <TextBlock Text="{Binding Description}"
                                                   BaselineOffset="11"
                                                   Foreground="{StaticResource SecondaryForeground}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3"
                                               Text="{Binding Status}">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Fail">
                                                                <Setter Property="Foreground" Value="{StaticResource BrandRedBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="CompletedSuccessfully">
                                                                <Setter Property="Foreground" Value="{StaticResource BrandGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Cancel">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <ProgressBar Grid.Row="1"
                                 Minimum="0" 
                                 Maximum="{Binding ProgressMax}" 
                                 Value="{Binding ProgressValue}"
                                 Background="{StaticResource BorderBrush}"
                                 Foreground="{StaticResource BrandRedBrush}"
                                 Height="6"/>
                </Grid>
            </Border>
            <Border Grid.Row="2"
                    Padding="28 16 28 24"
                    BorderThickness="0 1 0 0"
                    BorderBrush="{StaticResource BorderBrush}">
                <Grid HorizontalAlignment="Center">
                    <Button Content="Отмена"
                            Margin="0 0 6 0"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding ShowCancelButton, Converter={StaticResource BooleanToVisibilityConv}}"/>
                    <Button Content="Закрыть"
                            Margin="0 0 6 0"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CloseCommand}"
                            Visibility="{Binding ShowCancelButton, Converter={StaticResource InverseBooleanToVisibilityConv}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

<Window x:Class="InvestLens.App.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvestLens.App.UserControls"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:InvestLens.App.Behaviors"
        mc:Ignorable="d"
        Title="Registration" Height="835" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource WindowStyle}">

    <b:Interaction.Behaviors>
        <behaviors:DragMoveBehavior/>
    </b:Interaction.Behaviors>

    <Border Style="{StaticResource WindowBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                  Style="{StaticResource LeftSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="0 0 0 48">
                        <local:Logo/>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Margin="0 0 0 16">
                            <TextBlock Text="Начни свой путь" 
                                       Style="{StaticResource H2Style}"/>
                            <TextBlock Text="в инвестициях" 
                                       Style="{StaticResource H2Style}"/>
                        </StackPanel>
                        <TextBlock Text="Присоединяйтесь к тысячам инвесторов" 
                                   Style="{StaticResource PBlackStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📊" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Аналитика в реальном времени" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="📁" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Несколько портфелей" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="🔒" Style="{StaticResource PBlackStyle}" Margin="0 0 12 0"/>
                            <TextBlock Text="Безопасное хранение данных" Style="{StaticResource PBlackStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource RightSideStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0 0 0 28">
                        <TextBlock Text="Регистрация" 
                                   Style="{StaticResource H1Style}"/>
                        <TextBlock Text="Создайте аккаунт для начала работы" 
                                   Style="{StaticResource PWhiteStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0 0 8 20">
                                <Label Content="Имя" Target="NameTextBox"/>
                                <TextBox x:Name="NameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}">
                                    <b:Interaction.Behaviors>
                                        <behaviors:FocusBehavior/>
                                    </b:Interaction.Behaviors>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8 0 0 20">
                                <Label Content="Фамилия" Target="SurnameTextBox"/>
                                <TextBox x:Name="SurnameTextBox" Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0 0 0 20">
                            <Label Content="Login" Target="LoginTextBox"/>
                            <TextBox x:Name="LoginTextBox" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 0 4">
                            <Label Content="Пароль" Target="PasswordTextBox"/>
                            <StackPanel>
                                <PasswordBox x:Name="PasswordTextBox">
                                    <b:Interaction.Behaviors>
                                        <behaviors:PasswordBoxBehavior PropertyName="Password"/>
                                    </b:Interaction.Behaviors>
                                </PasswordBox>
                                <TextBlock Text="{Binding PasswordError}"
                                           Foreground="{StaticResource BrandRed}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0 0 0 14">
                            <Label Content="Подтверждение пароля" Target="ConfirmPasswordBox"/>
                            <StackPanel>
                                <PasswordBox x:Name="ConfirmPasswordBox">
                                    <b:Interaction.Behaviors>
                                        <behaviors:PasswordBoxBehavior PropertyName="ConfirmPassword"/>
                                    </b:Interaction.Behaviors>
                                </PasswordBox>
                                <TextBlock Text="{Binding ConfirmPasswordError}"
                                           Foreground="{StaticResource BrandRed}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="Создать аккаунт" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                IsDefault="True"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RegisterCommand}"/>
                        <Button Content="Выход" 
                                Padding="14"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0 0 0 24"
                                IsCancel="True"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Visibility="{Binding ShowErrorMessage, Converter={StaticResource BooleanToVisibilityConv}}"
                                   Style="{StaticResource ErrorMessageStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Уже есть аккаунт?"
                                   FontSize="14"
                                   Foreground="#5A6E8A"
                                   Margin="0 0 4 0"/>
                        <Button Content="Войти" 
                                FontWeight="Medium"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource LinkStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
